// Tang Nano 9K (GW1NR-9 QN88P) Pin Constraints
// eMMC Card Reader Project — FT245 FIFO variant

// ===========================================================
// System Clock - 27 MHz oscillator
// ===========================================================
IO_LOC  "clk_27m" 52;
IO_PORT "clk_27m" IO_TYPE=LVCMOS33 PULL_MODE=NONE;

// ===========================================================
// FT245 FIFO Data Bus (FT232H, Bank 2, 3.3V)
// Pin 25/26 reused from UART (ADBUS1/ADBUS0), 27-30/33-34 new
// ===========================================================
IO_LOC  "fifo_d[0]" 26;
IO_PORT "fifo_d[0]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;
IO_LOC  "fifo_d[1]" 25;
IO_PORT "fifo_d[1]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;
IO_LOC  "fifo_d[2]" 27;
IO_PORT "fifo_d[2]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;
IO_LOC  "fifo_d[3]" 28;
IO_PORT "fifo_d[3]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;
IO_LOC  "fifo_d[4]" 29;
IO_PORT "fifo_d[4]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;
IO_LOC  "fifo_d[5]" 30;
IO_PORT "fifo_d[5]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;
IO_LOC  "fifo_d[6]" 33;
IO_PORT "fifo_d[6]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;
IO_LOC  "fifo_d[7]" 34;
IO_PORT "fifo_d[7]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;

// ===========================================================
// FT245 FIFO Control (ACBUS0-3, Bank 1, 3.3V)
// PULL_MODE=UP on inputs: when FT232H disconnected, signals
// high = "no data / buffer full" = FIFO inactive
// ===========================================================
IO_LOC  "fifo_rxf_n" 35;
IO_PORT "fifo_rxf_n" IO_TYPE=LVCMOS33 PULL_MODE=UP;
IO_LOC  "fifo_txe_n" 40;
IO_PORT "fifo_txe_n" IO_TYPE=LVCMOS33 PULL_MODE=UP;
IO_LOC  "fifo_rd_n" 41;
IO_PORT "fifo_rd_n" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;
IO_LOC  "fifo_wr_n" 42;
IO_PORT "fifo_wr_n" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;

// ===========================================================
// LEDs (active low on Tang Nano 9K)
// ===========================================================
IO_LOC  "led[0]" 10;
IO_PORT "led[0]" IO_TYPE=LVCMOS18 PULL_MODE=NONE DRIVE=8;
IO_LOC  "led[1]" 11;
IO_PORT "led[1]" IO_TYPE=LVCMOS18 PULL_MODE=NONE DRIVE=8;
IO_LOC  "led[2]" 13;
IO_PORT "led[2]" IO_TYPE=LVCMOS18 PULL_MODE=NONE DRIVE=8;
IO_LOC  "led[3]" 14;
IO_PORT "led[3]" IO_TYPE=LVCMOS18 PULL_MODE=NONE DRIVE=8;
IO_LOC  "led[4]" 15;
IO_PORT "led[4]" IO_TYPE=LVCMOS18 PULL_MODE=NONE DRIVE=8;
IO_LOC  "led[5]" 16;
IO_PORT "led[5]" IO_TYPE=LVCMOS18 PULL_MODE=NONE DRIVE=8;

// ===========================================================
// Buttons (active low, directly on FPGA)
// ===========================================================
IO_LOC  "btn_s1" 3;
IO_PORT "btn_s1" IO_TYPE=LVCMOS18 PULL_MODE=UP;
IO_LOC  "btn_s2" 4;
IO_PORT "btn_s2" IO_TYPE=LVCMOS18 PULL_MODE=UP;

// ===========================================================
// eMMC Interface (BANK3, 1.8V)
// ===========================================================
IO_LOC  "emmc_clk" 82;
IO_PORT "emmc_clk" IO_TYPE=LVCMOS18 PULL_MODE=NONE DRIVE=8;
IO_LOC  "emmc_rstn" 81;
IO_PORT "emmc_rstn" IO_TYPE=LVCMOS18 PULL_MODE=NONE DRIVE=8;
IO_LOC  "emmc_cmd" 79;
IO_PORT "emmc_cmd" IO_TYPE=LVCMOS18 PULL_MODE=UP DRIVE=8;
IO_LOC  "emmc_dat0" 80;
IO_PORT "emmc_dat0" IO_TYPE=LVCMOS18 PULL_MODE=UP DRIVE=8;
IO_LOC  "emmc_dat1" 83;
IO_PORT "emmc_dat1" IO_TYPE=LVCMOS18 PULL_MODE=UP DRIVE=8;
IO_LOC  "emmc_dat2" 84;
IO_PORT "emmc_dat2" IO_TYPE=LVCMOS18 PULL_MODE=UP DRIVE=8;
IO_LOC  "emmc_dat3" 85;
IO_PORT "emmc_dat3" IO_TYPE=LVCMOS18 PULL_MODE=UP DRIVE=8;
